# CyberMOMO 环境变量示例 — 复制到 .env(不进 git)
# 适用于本地开发;Railway 上直接在 Dashboard Variables 配置

# ========================================
# 后端(apps/api)
# ========================================

# 数据库
# 本地:docker-compose 起的 Postgres
DATABASE_URL=postgresql+asyncpg://cybermomo:cybermomo_dev@localhost:5432/cybermomo
# Railway:Postgres 插件自动注入 DATABASE_URL,需要手动改成 asyncpg 格式
# DATABASE_URL=${{Postgres.DATABASE_URL}}  # 然后在代码里把 postgres:// 替换为 postgresql+asyncpg://

# CORS(前端访问后端)
CORS_ORIGINS=http://localhost:3000

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
JWT_SECRET=  # openssl rand -hex 32 生成

# LLM keys
GLM_API_KEY=         # dashscope sk-sp-...
ANTHROPIC_API_KEY=   # sk-ant-...
ZHIPU_API_KEY=       # 智谱 embedding(可选,用于向量)

# Sentry(可选)
SENTRY_DSN=

# ========================================
# 前端(apps/web)
# ========================================

NEXT_PUBLIC_API_URL=http://localhost:8787
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # openssl rand -hex 32 生成
